# Server Configuration
PORT=3000

# Cache Configuration
CACHE_DIR=./cache
DATA_DIR=./data
CACHE_TTL_HOURS=24

# Overpass API Configuration
OVERPASS_TIMEOUT_MS=25000
OVERPASS_QUERY_TIMEOUT=180
OVERPASS_MIRRORS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter,https://overpass.openstreetmap.ru/api/interpreter

# Geocoding Configuration
PHOTON_URL=https://photon.komoot.io/api/
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
USER_AGENT=StravaSegmentPlanner/1.0 (contact: cyclist-planner@example.com)

# Bounding Box Limits (degrees)
MAX_BBOX_LAT_SPAN=0.25
MAX_BBOX_LON_SPAN=0.35

# Spatial Index Configuration
SPATIAL_INDEX_CELL_DEG=0.001

# Routing Configuration
DETOUR_CANDIDATE_LIMIT=30
DETOUR_OVERLAP_PENALTY_METERS=2000
DETOUR_SEARCH_MULTIPLIER=2.5
